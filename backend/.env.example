# ── Railway Auto-Sets These ────────────────────────────────
# DATABASE_URL=mysql://root:password@host:port/dbname
# PORT=auto-set by Railway, do NOT set manually

# ── Set These Manually in Railway Variables ────────────────
NODE_ENV=production

# JWT (WAJIB - ganti dengan string random min 32 karakter)
JWT_SECRET=ganti_ini_dengan_string_random_panjang_min_32_karakter
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS - URL frontend Railway kamu
FRONTEND_URL=https://gphrdpro-production.up.railway.app

# ── Hanya Untuk Local Development (jika tidak pakai DATABASE_URL) ──
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=hrd_system
# DB_USER=root
# DB_PASSWORD=your_password
