# ── Server ──────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Railway MySQL ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hrd_system
DB_USER=root
DB_PASSWORD=your_password
# DATABASE_URL=mysql://... (Railway auto-sets this)

# ── JWT ───────────────────────────────────────
JWT_SECRET=your_super_secret_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ─────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Cloudinary (Face/Selfie Storage) ─────────
CLOUDINARY_CLOUD_NAME=ddkserhag
CLOUDINARY_API_KEY=542531932752582
CLOUDINARY_API_SECRET=your_actual_secret_here
CLOUDINARY_UPLOAD_PRESET=hrd_attendance
